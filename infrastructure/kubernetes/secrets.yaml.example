# Kubernetes Secrets - EXAMPLE FILE
#
# Copy this file to secrets.yaml and replace all placeholder values with actual secrets
# DO NOT commit secrets.yaml to version control - it's in .gitignore
#
# To encode a value to base64:
#   echo -n "your-secret-value" | base64
#
# Or use kubectl:
#   kubectl create secret generic app-secrets --from-literal=JWT_SECRET=your-secret --dry-run=client -o yaml

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: job-tracker
type: Opaque
data:
  # Replace with: echo -n "your-postgres-password" | base64
  postgres-password: Y2hhbmdlLW1lLXBvc3RncmVzLXBhc3N3b3Jk  # "change-me-postgres-password"

---
apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: job-tracker
type: Opaque
data:
  # Replace with: openssl rand -base64 32 | base64
  jwt-secret: Y2hhbmdlLW1lLWp3dC1zZWNyZXQtbXVzdC1iZS0zMi1jaGFycy1taW5pbXVtLWZvci1zZWN1cml0eQ==  # Must be 32+ chars

  # AWS credentials (if using S3)
  aws-access-key-id: ""  # Optional - leave empty if not using S3
  aws-secret-access-key: ""  # Optional - leave empty if not using S3

---
apiVersion: v1
kind: Secret
metadata:
  name: frontend-secret
  namespace: job-tracker
type: Opaque
data:
  # Replace with: openssl rand -base64 32 | base64
  nextauth-secret: Y2hhbmdlLW1lLW5leHRhdXRoLXNlY3JldC1tdXN0LWJlLTMyLWNoYXJzLW1pbmltdW0=  # Must be 32+ chars

  # Google OAuth (optional)
  google-client-id: ""  # Optional - leave empty if not using Google OAuth
  google-client-secret: ""  # Optional - leave empty if not using Google OAuth

---
apiVersion: v1
kind: Secret
metadata:
  name: ai-service-secret
  namespace: job-tracker
type: Opaque
data:
  # AI service credentials
  gemini-api-key: Y2hhbmdlLW1lLWdlbWluaS1hcGkta2V5  # "change-me-gemini-api-key"
  pinecone-api-key: Y2hhbmdlLW1lLXBpbmVjb25lLWFwaS1rZXk=  # "change-me-pinecone-api-key"
  ai-service-api-key: Y2hhbmdlLW1lLWFpLXNlcnZpY2UtYXBpLWtleQ==  # "change-me-ai-service-api-key"
