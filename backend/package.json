{
  "name": "backend",
  "version": "1.0.0",
  "description": "Job Tracker Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "docs": "node api-docs-server.js",
    "build": "npm run clean && tsc && npx tsc-alias --resolve-full-paths",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/scripts/seed.ts",
    "s3:setup-cors": "tsx scripts/setup-s3-cors.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "npm run lint:check && npm run type-check"
  },
  "keywords": [
    "express",
    "typescript",
    "drizzle",
    "job-tracker"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.840.0",
    "@aws-sdk/s3-request-presigner": "^3.840.0",
    "@google/generative-ai": "^0.24.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dompurify": "^3.2.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pdfjs-dist": "^5.4.624",
    "pg": "^8.18.0",
    "postgres": "^3.4.8",
    "resend": "^6.9.3",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.8.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/chrome": "^0.1.1",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.30.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.35.1"
  }
}
