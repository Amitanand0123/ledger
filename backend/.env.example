# Application & Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3021

# Database (for local Docker setup)
DATABASE_URL="postgresql://postgres:password@postgres:5433/ledger"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-that-is-long-and-secure"


# File Storage (AWS S3)
AWS_ACCESS_KEY_ID=YOUR_IAM_USER_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_IAM_USER_SECRET_ACCESS_KEY
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=your-s3-bucket-region # e.g., us-east-1

# AI Integration
GEMINI_API_KEY=your-gemini-api-key
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your-ai-service-api-key